rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailAdmin() {
      return isSignedIn() && 
        request.auth.token.email != null && 
        (request.auth.token.email == 'admin@walletpro.com' || request.auth.token.email == 'nafizsoftvence@gmail.com');
    }

    // --- User Collection Rules ---
    match /users/{userId} {
      // Allows agents and admins to read profiles for customer lookups and approval listings safely
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (
        request.auth.token.email == 'admin@walletpro.com' ||
        request.auth.token.email == 'nafizsoftvence@gmail.com' ||
        isEmailAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // --- Transaction Collection Rules ---
    match /transactions/{transactionId} {
      // Enables full financial operations, deposits, and withdrawal logging for authenticated users
      allow read, write: if isSignedIn();
    }

    // --- Settings Collection Rules ---
    match /settings/{document} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isEmailAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // --- System Logs Collection Rules ---
    match /system_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // --- Receivers Collection Rules ---
    match /receivers/{receiverId} {
      allow read, write: if isSignedIn();
    }

    // --- Feedback Collection Rules ---
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        isEmailAdmin() ||
        resource.data.userId == request.auth.uid || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
      allow update, delete: if isSignedIn() && (
        isEmailAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // --- Email Logs Collection Rules ---
    match /email_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
